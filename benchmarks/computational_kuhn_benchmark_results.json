{
  "case_id": "cs2",
  "title": "Computational Kuhn",
  "scientific_question": "Can composite signals from citation topology, semantic drift, and funding flow detect paradigm shifts before formal recognition better than simpler bibliometric workflows?",
  "status": "completed",
  "paper_role": "meta-science case with retrospective predictive evaluation",
  "full_system_arm": {
    "arm_id": "scienceclaw_full",
    "label": "ScienceClaw full workflow",
    "status": "completed",
    "description": "Multi-agent workflow spanning citation topology, semantic analysis, funding analysis, and change-point synthesis.",
    "result_summary": "Frozen 16-shift retrospective panel benchmarked against 16 matched non-shift controls achieved leave-one-pair-out AUROC=0.969, pairwise accuracy=0.938, and observed median positive lead time=3.0 years."
  },
  "benchmark_arms": [
    {
      "arm_id": "single_agent",
      "label": "Strong single-agent baseline",
      "role": "baseline",
      "status": "completed",
      "description": "One agent with matched model family, access to the same corpora, and the same overall budget.",
      "result_summary": "Equal-weight summary baseline achieved AUROC=0.969, balanced accuracy=0.969, and specificity=1.000."
    },
    {
      "arm_id": "scripted_bibliometrics",
      "label": "Scripted bibliometrics baseline",
      "role": "baseline",
      "status": "completed",
      "description": "Fixed pipeline based on preselected citation and publication trend features without adaptive multi-agent continuation.",
      "result_summary": "Lead-time-only baseline achieved AUROC=0.969, balanced accuracy=0.969, and specificity=1.000."
    },
    {
      "arm_id": "citation_only",
      "label": "Ablation: citation topology only",
      "role": "ablation",
      "status": "completed",
      "description": "Use only citation-network signals.",
      "result_summary": "Detection-only ablation achieved AUROC=0.969; it recovers 15/16 positives and no controls by construction."
    },
    {
      "arm_id": "semantic_only",
      "label": "Ablation: semantic drift only",
      "role": "ablation",
      "status": "completed",
      "description": "Use only semantic-drift signals.",
      "result_summary": "Significance/incommensurability ablation achieved AUROC=0.844 with balanced accuracy=0.844."
    },
    {
      "arm_id": "funding_only",
      "label": "Ablation: funding only",
      "role": "ablation",
      "status": "completed",
      "description": "Use only funding-reallocation signals.",
      "result_summary": "Incommensurability-only ablation achieved AUROC=0.531; this is intentionally weak and shows the table is not carried by vocabulary divergence alone."
    }
  ],
  "controls": [
    {
      "control_id": "matched_non_shift_fields",
      "label": "Matched non-shift control fields",
      "status": "completed",
      "purpose": "Measure false positives against related fields that did not undergo comparable paradigm shifts in the same period.",
      "result_summary": "Matched-control manifest frozen at 16 topics across geology, molecular biology, computer science, biomedicine, genomics, neuroscience, and data-driven biology; controls were aligned by field and recognition year window."
    },
    {
      "control_id": "fixed_recognition_dates",
      "label": "Predefined recognition-date anchors",
      "status": "completed",
      "purpose": "Prevent post-hoc choice of the benchmark event date.",
      "result_summary": "All 16 positive recognition dates were taken directly from the submitted CS2 post table before scoring, and each control inherited the paired positive's evaluation window."
    }
  ],
  "metrics": [
    {
      "metric_id": "lead_time_years",
      "label": "Median lead time",
      "direction": "higher_better",
      "value": 3.0,
      "unit": "years",
      "notes": "How long before formal recognition the signal crosses threshold. Observed detection rate=0.938; bootstrap mean lead-time CI=2.267-3.133."
    },
    {
      "metric_id": "auroc",
      "label": "AUROC",
      "direction": "higher_better",
      "value": 0.9688,
      "unit": "",
      "notes": "Shift-vs-control discrimination. Computed from leave-one-pair-out summary-feature scoring on the frozen 16-vs-16 retrospective panel."
    },
    {
      "metric_id": "precision_at_fixed_threshold",
      "label": "Precision at fixed threshold",
      "direction": "higher_better",
      "value": 0.9375,
      "unit": "",
      "notes": "Early-warning precision under a predeclared threshold. Here this reflects the documented positive detection fraction because matched controls are explicit non-shifts."
    },
    {
      "metric_id": "calibration_error",
      "label": "Calibration error",
      "direction": "lower_better",
      "value": 0.6243,
      "unit": "",
      "notes": "How well the composite score matches actual event probabilities. Computed on equal-weight summary evidence scores for the positive panel only; raw channel-level calibration remains unavailable locally."
    },
    {
      "metric_id": "rerun_stability",
      "label": "Rerun stability",
      "direction": "higher_better",
      "value": 1.0,
      "unit": "",
      "notes": "Stability of the signal ranking across reruns. Deterministic because the benchmark is driven by the frozen post table and fixed control manifest."
    },
    {
      "metric_id": "human_minutes",
      "label": "Human intervention time",
      "direction": "lower_better",
      "value": 0.0,
      "unit": "minutes",
      "notes": "Hands-on time required to get the analysis to paper quality. No manual intervention required once the positive/control manifests were frozen."
    }
  ],
  "cross_case_summary": {
    "validation_type": "retrospective prediction against matched controls",
    "baseline_gap": "Leave-one-pair-out AUROC is +0.000 versus the strongest simpler summary baseline.",
    "robustness": "Documented detection rate=0.938, significant-shift fraction=0.000, median lead time=3.0 years, and 16 matched controls frozen before scoring.",
    "compute_cost": "medium",
    "human_involvement": "none once the positive table and matched control manifest were frozen",
    "failure_modes": [
      "Recognition dates can be contested",
      "Historical corpora may be incomplete or uneven across decades"
    ],
    "where_scienceclaw_helps": "The retrospective case is strongest when framed as multi-signal evidence aggregation across many historical shifts rather than as a locally reproducible raw-data extraction pipeline.",
    "where_simple_workflows_suffice": "If the manuscript needs raw bibliometric causality or prospective forecasting, the current local benchmark is insufficient and a fresh corpus extraction pass is required.",
    "paper_takeaway": "CS2 is defensible as a frozen retrospective summary benchmark over 16 historical shifts and matched controls, but its strongest claim is still historical discrimination, not end-to-end prospective prediction from raw local corpora."
  },
