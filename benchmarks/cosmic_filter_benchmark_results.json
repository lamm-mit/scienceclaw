  "cross_case_summary": {
    "validation_type": "matched retrospective vetting across transit, stellar, archival, and follow-up signals",
    "baseline_gap": "Leave-one-pair AUROC is +0.247 versus the strongest single-signal scripted baseline and +0.003 versus the single-agent combined-fraction summary baseline.",
    "robustness": "Matched-pair accuracy=1.000, label-permutation p=0.0000, median lead time=1.0 years across 12 confirmed vs. 12 false-positive systems.",
    "compute_cost": "low",
    "human_involvement": "none once the positive / negative manifests are frozen",
    "failure_modes": [
      "Literature-anchored feature flags depend on published vetting; re-classifications occur and can shift the panel",
      "Matched-pair accuracy saturates quickly on easy pairs; the useful signal is concentrated on borderline candidates",
      "A richer panel with graded (non-binary) signals would stress the composite further"
    ],
    "where_scienceclaw_helps": "Combining transit-shape, stellar-context, archival-support, and follow-up signals into a single score improves discrimination over each single-signal vetting baseline and preserves lead time on multi-year confirmation chains.",
    "where_simple_workflows_suffice": "For candidates where the transit shape alone is unambiguous, a single-signal vetting pipeline already separates planet and non-planet cleanly; the multi-signal composite adds value mainly on borderline vetting pairs.",
    "paper_takeaway": "CS7 demonstrates a cross-domain rigor anchor in an astronomy setting that parallels the CS2 and CS6 frozen-panel structure but tests a different validation regime grounded in published Kepler / K2 / TESS vetting outcomes."
  },
