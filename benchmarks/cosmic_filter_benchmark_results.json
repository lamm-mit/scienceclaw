{
  "case_id": "cs7",
  "title": "The Cosmic Filter",
  "scientific_question": "Can a composite of transit-shape, stellar-context, archival-support, and follow-up-confirmation signals discriminate true transiting exoplanets from false-positive candidates better than single-signal vetting baselines on a frozen retrospective panel?",
  "status": "completed",
  "paper_role": "astronomy / stellar-astrophysics rigor anchor with matched-pair retrospective evaluation",
  "full_system_arm": {
    "arm_id": "scienceclaw_full",
    "label": "ScienceClaw full workflow",
    "status": "completed",
    "description": "Multi-agent vetting workflow combining transit-shape, stellar-context, archival-support, and follow-up signals on a frozen 12-confirmed vs. 12-false-positive retrospective panel.",
    "result_summary": "Leave-one-pair AUROC=0.955, matched-pair accuracy=1.000, median positive lead time=1.0 years."
  },
  "benchmark_arms": [
    {
      "arm_id": "single_agent",
      "label": "Strong single-agent baseline",
      "role": "baseline",
      "status": "completed",
      "description": "One-agent detector scoring only the combined-signal-fraction summary.",
      "result_summary": "Combined-fraction-only AUROC=0.951, balanced accuracy=0.792."
    },
    {
      "arm_id": "scripted_transit_shape_only",
      "label": "Scripted transit-shape-only baseline",
      "role": "baseline",
      "status": "completed",
      "description": "Fixed scripted vetting pipeline based only on transit-shape consistency.",
      "result_summary": "Shape-only baseline AUROC=0.708."
    },
    {
      "arm_id": "shape_plus_stellar",
      "label": "Ablation: transit shape + stellar context only",
      "role": "ablation",
      "status": "completed",
      "description": "Use only the two on-target vetting signals (shape + stellar).",
      "result_summary": "Shape+stellar AUROC=0.781."
    },
    {
      "arm_id": "no_archival",
      "label": "Ablation: no archival support",
      "role": "ablation",
      "status": "completed",
      "description": "Remove cross-archive (multi-mission / RV archival) evidence from the composite.",
      "result_summary": "No-archival AUROC=0.958."
    },
    {
      "arm_id": "no_followup",
      "label": "Ablation: no follow-up confirmation",
      "role": "ablation",
      "status": "completed",
      "description": "Remove RV/TTV follow-up confirmation from the composite.",
      "result_summary": "No-followup AUROC=0.851."
    }
  ],
  "controls": [
    {
      "control_id": "matched_false_positive_controls",
      "label": "Matched false-positive controls",
      "status": "completed",
      "purpose": "Measure discrimination against same-mission, same-era candidates dispositioned as false positives in the published vetting literature.",
      "result_summary": "Control manifest frozen at 12 false-positive candidates across Kepler, K2, TESS, and MEarth missions."
    },
    {
      "control_id": "label_permutation",
      "label": "Label-permutation null",
      "status": "completed",
      "purpose": "Test observed AUROC against random relabelings.",
      "result_summary": "Observed AUROC=0.955 versus null mean=0.498 (permutation p=0.0000)."
    },
    {
      "control_id": "fixed_disposition_anchors",
      "label": "Frozen disposition / confirmation anchors",
      "status": "completed",
      "purpose": "Prevent post-hoc flipping of disposition; confirmation and false-positive years are taken from cited literature before scoring.",
      "result_summary": "All 12 confirmation years and 12 disposition years frozen before scoring."
    }
  ],
